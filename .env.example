# =============================================================
# Variáveis de ambiente do frontend (Vite)
# -------------------------------------------------------------
# Copie este arquivo para ".env" (ou ".env.local") e preencha
# com os valores do seu projeto Supabase.
#
#   Supabase Dashboard > Project Settings > API
#
# IMPORTANTE:
#  - Use APENAS a chave "anon public".
#  - A chave "service_role" NUNCA deve ser usada no frontend.
#  - Não faça commit do arquivo .env (já está no .gitignore).
# =============================================================

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
